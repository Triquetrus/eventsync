rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isValidEvent(data) {
      return data.id is string && data.id.size() <= 128
        && data.name is string && data.name.size() <= 200
        && data.date is string && data.date.size() <= 30
        && data.time is string && data.time.size() <= 30
        && data.location is string && data.location.size() <= 500
        && data.type is string && data.type.size() <= 50
        && data.description is string && data.description.size() <= 2000
        && data.status is string && data.status.size() <= 50
        && data.smartPrompts is list
        && (!data.keys().hasAll(['userEmail']) || (data.userEmail is string && data.userEmail.size() <= 200));
    }

    match /events/{eventId} {
      allow read: if request.auth != null && resource.data.userEmail == request.auth.token.email;
      allow create: if request.auth != null && isValidId(eventId) && isValidEvent(request.resource.data) && request.resource.data.userEmail == request.auth.token.email;
      allow update: if request.auth != null && isValidId(eventId) && isValidEvent(request.resource.data) && resource.data.userEmail == request.auth.token.email && request.resource.data.userEmail == request.auth.token.email;
      allow delete: if request.auth != null && isValidId(eventId) && resource.data.userEmail == request.auth.token.email;
    }

    match /media/{mediaId} {
      allow read: if request.auth != null && resource.data.userEmail == request.auth.token.email;
      allow create: if request.auth != null && isValidId(mediaId) && request.resource.data.userEmail == request.auth.token.email;
      allow update: if request.auth != null && isValidId(mediaId) && resource.data.userEmail == request.auth.token.email && request.resource.data.userEmail == request.auth.token.email;
      allow delete: if request.auth != null && isValidId(mediaId) && resource.data.userEmail == request.auth.token.email;
    }

    match /captions/{captionId} {
      allow read: if request.auth != null && resource.data.userEmail == request.auth.token.email;
      allow create: if request.auth != null && isValidId(captionId) && request.resource.data.userEmail == request.auth.token.email;
      allow update: if request.auth != null && isValidId(captionId) && resource.data.userEmail == request.auth.token.email && request.resource.data.userEmail == request.auth.token.email;
      allow delete: if request.auth != null && isValidId(captionId) && resource.data.userEmail == request.auth.token.email;
    }
  }
}
